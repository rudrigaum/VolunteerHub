# Set the default behavior, in case people don't have core.autocrlf set.
* text=auto eol=lf

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.kt text eol=lf
*.kts text eol=lf
*.swift text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# iOS specific - tell git not to mess with these binary/pbxproj files
*.pbxproj binary
*.xcworkspace/contents.xcworkspacedata binary
*.xcscheme binary
