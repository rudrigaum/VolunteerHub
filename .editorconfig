# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# Android/Kotlin/Java
[*.{kt,kts,java,xml}]
indent_style = space
indent_size = 4

# iOS/Swift
[*.swift]
indent_style = space
indent_size = 4

# Gradle/Groovy
[*.gradle]
indent_style = space
indent_size = 4

# Web/Config/Docs
[*.{json,yml,yaml,md,html,css,js}]
indent_style = space
indent_size = 2
